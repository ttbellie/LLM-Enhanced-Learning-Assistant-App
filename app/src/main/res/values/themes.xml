<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.LLMLearningAssistant" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_cyan</item>
        <item name="colorPrimaryVariant">@color/brand_cyan_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">@color/accent_green_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/brand_cyan</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/brand_cyan</item>
    </style>

    <style name="Theme.LLMLearningAssistant.Splash" parent="Theme.LLMLearningAssistant">
        <item name="android:windowBackground">@color/brand_cyan</item>
    </style>

    <!-- Common text styles -->
    <style name="AppText.Title" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">36sp</item>
    </style>

    <style name="AppText.Subtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="AppText.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Input field -->
    <style name="AppInput" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/input_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Primary green button -->
    <style name="AppButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="backgroundTint">@color/accent_green</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Secondary button -->
    <style name="AppButton.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/brand_cyan_dark</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="cornerRadius">10dp</item>
    </style>

</resources>
